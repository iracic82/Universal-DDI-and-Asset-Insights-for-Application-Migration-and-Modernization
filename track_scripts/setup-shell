#!/bin/bash
apt update -y
apt install git -y
wget -O- https://apt.releases.hashicorp.com/gpg | gpg --dearmor | tee /usr/share/keyrings/hashicorp-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/hashicorp.list
apt update -y
apt install -y git terraform ansible python3-pip jq
apt install -y netcat-openbsd
apt-get update && apt-get install -y libxml2-utils
pip3 install pywinrm
pip3 install requests

mkdir -p /root/infoblox-lab
git clone https://github.com/iracic82/app-migration-niosx.git
cp -r /root/app-migration-niosx /root/infoblox-lab/

echo "export TF_VAR_Access_Key_AWS=${INSTRUQT_AWS_ACCOUNT_INFOBLOX_DEMO_AWS_ACCESS_KEY_ID} " >> /root/.bashrc
echo "export TF_VAR_Access_Secret_AWS=${INSTRUQT_AWS_ACCOUNT_INFOBLOX_DEMO_AWS_SECRET_ACCESS_KEY} " >> /root/.bashrc
echo "export TF_VAR_windows_admin_password=${TF_VAR_windows_admin_password} " >> /root/.bashrc
echo "export DEMO_AWS_ACCESS_KEY_ID=${DEMO_AWS_ACCESS_KEY_ID} " >> /root/.bashrc
echo "export DEMO_AWS_SECRET_ACCESS_KEY=${DEMO_AWS_SECRET_ACCESS_KEY} " >> /root/.bashrc
echo "export DEMO_HOSTED_ZONE_ID=${DEMO_HOSTED_ZONE_ID} " >> /root/.bashrc
echo "export Infoblox_Token=${Infoblox_Token} " >> /root/.bashrc
echo "export TF_VAR_instruqt_id=${INSTRUQT_PARTICIPANT_ID} " >> /root/.bashrc
echo "export INFOBLOX_EMAIL=${INFOBLOX_EMAIL} " >> /root/.bashrc
echo "export INFOBLOX_PASSWORD=${INFOBLOX_PASSWORD} " >> /root/.bashrc
echo "export INSTRUQT_EMAIL=${INSTRUQT_USER_EMAIL} " >> /root/.bashrc
echo "export AWS_REGION=eu-central-1" >> /root/.bashrc
source ~/.bashrc





# Make sure region is exported NOW for this script/process
export AWS_REGION="eu-central-1"





# Run Python scripts
cd /root/infoblox-lab/app-migration-niosx/terraform/scripts
#python3 setup_dns.py
sleep 10
#python3 create_dns_gm.py
sleep 180
python3 create_sandbox.py
sleep 60
python3 create_user.py
sleep 60
python3 deploy_api_key.py
sleep 60
python3 infoblox_create_join_token.py

source ~/.bashrc

echo "export TF_VAR_infoblox_join_token=${INFOBLOX_JOIN_TOKEN} " >> /root/.bashrc

source ~/.bashrc

cd /root/infoblox-lab/app-migration-niosx/terraform
terraform init
terraform apply -auto-approve


sleep 120

# Fetch client IP (DC1) from Terraform output
DC1_IP=$(terraform output -raw client_public_ip)

# Export to current session and persist to bashrc
export DC1_IP
echo "export DC1_IP=${DC1_IP}" >> /root/.bashrc

# Get EC2 instance ID for client
DC1_ID=$(aws ec2 describe-instances --region $AWS_REGION --filters "Name=ip-address,Values=${DC1_IP}" --query "Reservations[].Instances[].InstanceId" --output text)

if [[ -z "$DC1_ID" || "$DC1_ID" == "None" ]]; then
  echo "ERROR: DC1_ID not found. Check region and IP."
  exit 1
fi

# Fetch Windows admin password
function get_password {
  local instance_id=$1
  local privkey=$2
  for i in {1..12}; do
    pass=$(aws ec2 get-password-data --region $AWS_REGION --instance-id "$instance_id" --priv-launch-key "$privkey" --query 'PasswordData' --output text)
    if [[ "$pass" != "None" && "$pass" != "" ]]; then
      echo "$pass"
      return 0
    fi
    echo "Waiting for password for instance $instance_id..."
    sleep 10
  done
  echo "FAILED-TO-GET-PASSWORD"
}


source ~/.bashrc

# Run Python scripts again
cd /root/infoblox-lab/app-migration-niosx/terraform/scripts
python3 setup_dns.py
sleep 10

sleep 60


# Set AWS creds
cp ~/.aws/credentials /root/infoblox-lab/app-migration-niosx/terraform