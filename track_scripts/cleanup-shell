#!/bin/bash
#
# This script runs when the platform sets up or tears down the challenge.
# The platform determines success via the exit code — exit 0 = success.
#

echo "🧹 Running cleanup script..."

cd /root/infoblox-lab/app-migration-niosx/terraform/scripts || {
  echo "❌ Failed to cd into script directory. Exiting."
  exit 1
}

# Run each script but don't fail the whole cleanup if one fails

echo "🔧 Running purge_discovery_jobs.py"
python3 purge_discovery_jobs.py || echo "⚠️ purge_discovery_jobs.py failed, continuing..."

sleep 10

echo "🔧 Running cleanup_dns_records.py"
python3 cleanup_dns_records.py || echo "⚠️ cleanup_dns_records.py failed, continuing..."

sleep 10

echo "🔧 Running delete_sandbox.py"
python3 delete_sandbox.py || echo "⚠️ delete_sandbox.py failed, continuing..."

sleep 10

echo "🔧 Running delete_user.py"
if [ -f user_id.txt ]; then
  python3 delete_user.py || echo "⚠️ delete_user.py failed, continuing..."
else
  echo "⚠️ Skipping delete_user.py: user_id.txt not found"
fi

sleep 10

echo "🔧 Running clean_dns_gm.py"
python3 clean_dns_gm.py || echo "⚠️ clean_dns_gm.py failed, continuing..."

echo "✅ Cleanup complete"
exit 0